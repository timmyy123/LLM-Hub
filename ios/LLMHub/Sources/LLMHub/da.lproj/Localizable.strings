"tos_last_updated" = "Sidst opdateret: 16. juli 2025";
"tos_welcome_text" = "Velkommen til LLM Hub. Ved at bruge vores applikation accepterer du at være bundet af disse servicevilkår. Læs dem venligst omhyggeligt.";
"tos_welcome" = "Velkommen til LLM Hub. Ved at bruge vores applikation accepterer du at være bundet af disse servicevilkår. Læs dem venligst omhyggeligt.";
"tos_acceptance_title" = "1. Accept af vilkår";
"tos_acceptance_text" = "Ved at downloade, installere eller bruge LLM Hub, anerkender du, at du har læst, forstået og accepterer at være bundet af disse Servicevilkår. Hvis du ikke accepterer disse vilkår, skal du ikke bruge applikationen.";
"tos_app_description_title" = "2. Anvendelsesbeskrivelse";
"tos_app_description_text" = "LLM Hub er en open source-applikation, der giver adgang til store sprogmodeller (LLM'er) til AI-samtaler på enheden. Appen behandler alle data lokalt på din enhed og sender ikke personlige oplysninger til eksterne servere.";
"tos_user_responsibilities_title" = "3. Brugeransvar";
"tos_user_responsibilities_text" = "Du accepterer at bruge LLM Hub ansvarligt og i overensstemmelse med gældende love. Du er ansvarlig for:\\n\\n• Kun at bruge applikationen til lovlige formål\\n• Ikke at forsøge at reverse engineering eller modificere applikationen\\n• Ikke at bruge applikationen til at generere skadeligt, ulovligt eller stødende indhold\\n• Respektere de intellektuelle ejendomsrettigheder for din tredjeparts enhed, der opfylder minimumskravene til enhedens ___NL__";
"tos_privacy_data_title" = "4. Privatliv og data";
"tos_privacy_data_text" = "LLM Hub er designet med privatliv i tankerne:\\n\\n• Alle samtaler og databehandling foregår lokalt på din enhed\\n• Ingen personlige data overføres til eksterne servere\\n• Chathistorik gemmes lokalt og kan til enhver tid slettes\\n• Modeldownloads udføres direkte fra officielle applikationsarkiver, •____ indsamler ikke Googles officielle applikationslagre (Hugging ___) analyse- eller brugsdata";
"tos_disclaimer_title" = "5. Ansvarsfraskrivelse";
"tos_disclaimer_text" = "LLM Hub leveres \"som den er\" uden garantier af nogen art. Vi garanterer ikke for nøjagtigheden, pålideligheden eller tilgængeligheden af ​​applikationen eller dens genererede indhold. Brug af AI-modeller kan give uforudsigelige resultater.";
"tos_limitation_liability_title" = "6. Ansvarsbegrænsning";
"tos_limitation_liability_text" = "Udviklerne kan under ingen omstændigheder holdes ansvarlige for indirekte, tilfældige, specielle eller følgeskader, der opstår som følge af brugen af ​​LLM Hub. Din brug af applikationen er på eget ansvar.";
"tos_model_usage_title" = "7. Modelbrug og licensering";
"tos_model_usage_text" = "AI-modellerne, der er tilgængelige via LLM Hub, er underlagt deres respektive licenser og brugsbetingelser. Brugere er ansvarlige for at overholde modelspecifikke licenskrav, når de bruger downloadede modeller.";
"tos_open_source_title" = "8. Open Source-licens";
"tos_open_source_text" = "LLM Hub er open source-software. Kildekoden er tilgængelig under den ikke-kommercielle licens, som tillader brug, ændring og distribution i henhold til licensbetingelserne. Tredjepartsbiblioteker og -modeller kan have forskellige licensvilkår.";
"tos_changes_title" = "9. Ændringer af vilkår";
"tos_changes_text" = "Vi kan opdatere disse servicevilkår fra tid til anden. Brugere vil blive underrettet om væsentlige ændringer gennem appopdateringer. Fortsat brug af applikationen efter ændringer udgør accept af de nye vilkår.";
"tos_contact_title" = "10. Kontaktoplysninger";
"tos_contact_text" = "For spørgsmål om disse servicevilkår bedes du kontakte os på timmy@LLM Hub.app";
