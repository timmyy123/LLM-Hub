"tos_last_updated" = "Cập nhật lần cuối: Ngày 16 tháng 7 năm 2025";
"tos_welcome_text" = "Chào mừng đến với LLM Hub. Bằng cách sử dụng ứng dụng của chúng tôi, bạn đồng ý bị ràng buộc bởi các Điều khoản dịch vụ này. Xin vui lòng đọc chúng một cách cẩn thận.";
"tos_welcome" = "Chào mừng đến với LLM Hub. Bằng cách sử dụng ứng dụng của chúng tôi, bạn đồng ý bị ràng buộc bởi các Điều khoản dịch vụ này. Xin vui lòng đọc chúng một cách cẩn thận.";
"tos_acceptance_title" = "1. Chấp nhận các điều khoản";
"tos_acceptance_text" = "Bằng cách tải xuống, cài đặt hoặc sử dụng LLM Hub, bạn xác nhận rằng bạn đã đọc, hiểu và đồng ý bị ràng buộc bởi các Điều khoản dịch vụ này. Nếu bạn không đồng ý với các điều khoản này, vui lòng không sử dụng ứng dụng.";
"tos_app_description_title" = "2. Mô tả ứng dụng";
"tos_app_description_text" = "LLM Hub là một ứng dụng nguồn mở cung cấp quyền truy cập vào Mô hình ngôn ngữ lớn (LLM) cho các cuộc hội thoại AI trên thiết bị. Ứng dụng xử lý tất cả dữ liệu cục bộ trên thiết bị của bạn và không truyền thông tin cá nhân đến máy chủ bên ngoài.";
"tos_user_responsibilities_title" = "3. Trách nhiệm của Người dùng";
"tos_user_responsibilities_text" = "Bạn đồng ý sử dụng LLM Hub một cách có trách nhiệm và phù hợp với pháp luật hiện hành. Bạn chịu trách nhiệm về:\\n\\n• Chỉ sử dụng ứng dụng cho các mục đích hợp pháp\\n• Không cố gắng đảo ngược kỹ thuật hoặc sửa đổi ứng dụng\\n• Không sử dụng ứng dụng để tạo ra nội dung có hại, bất hợp pháp hoặc xúc phạm\\n• Tôn trọng quyền sở hữu trí tuệ của bên thứ ba\\n• Đảm bảo thiết bị của bạn đáp ứng các yêu cầu tối thiểu để hoạt động bình thường";
"tos_privacy_data_title" = "4. Quyền riêng tư và dữ liệu";
"tos_privacy_data_text" = "LLM Hub được thiết kế chú trọng đến quyền riêng tư:\\n\\n• Tất cả các cuộc hội thoại và xử lý dữ liệu diễn ra cục bộ trên thiết bị của bạn\\n• Không có dữ liệu cá nhân nào được truyền đến máy chủ bên ngoài\\n• Lịch sử trò chuyện được lưu trữ cục bộ và có thể bị xóa bất kỳ lúc nào\\n• Tải xuống mô hình được thực hiện trực tiếp từ kho lưu trữ chính thức (HuggingFace, Google)\\n• Ứng dụng không thu thập dữ liệu phân tích hoặc sử dụng";
"tos_disclaimer_title" = "5. Từ chối trách nhiệm bảo đảm";
"tos_disclaimer_text" = "LLM Hub được cung cấp \"nguyên trạng\" mà không có bất kỳ hình thức bảo đảm nào. Chúng tôi không đảm bảo tính chính xác, độ tin cậy hoặc tính khả dụng của ứng dụng hoặc nội dung do ứng dụng tạo ra. Việc sử dụng các mô hình AI có thể mang lại kết quả khó lường.";
"tos_limitation_liability_title" = "6. Giới hạn trách nhiệm pháp lý";
"tos_limitation_liability_text" = "Trong mọi trường hợp, nhà phát triển sẽ không chịu trách nhiệm về mọi thiệt hại gián tiếp, ngẫu nhiên, đặc biệt hoặc do hậu quả phát sinh từ việc sử dụng LLM Hub. Việc sử dụng ứng dụng của bạn có nguy cơ của riêng bạn.";
"tos_model_usage_title" = "7. Sử dụng mô hình và cấp phép";
"tos_model_usage_text" = "Các mô hình AI có sẵn thông qua LLM Hub phải tuân theo giấy phép và điều khoản sử dụng tương ứng. Người dùng có trách nhiệm tuân thủ các yêu cầu cấp phép dành riêng cho từng mẫu máy khi sử dụng các mẫu đã tải xuống.";
"tos_open_source_title" = "8. Giấy phép nguồn mở";
"tos_open_source_text" = "LLM Hub là phần mềm nguồn mở. Mã nguồn được cung cấp theo Giấy phép Phi thương mại, cho phép sử dụng, sửa đổi và phân phối theo các điều khoản của giấy phép. Các thư viện và mô hình của bên thứ ba có thể có các điều khoản cấp phép khác nhau.";
"tos_changes_title" = "9. Thay đổi Điều khoản";
"tos_changes_text" = "Thỉnh thoảng chúng tôi có thể cập nhật các Điều khoản dịch vụ này. Người dùng sẽ được thông báo về những thay đổi quan trọng thông qua các bản cập nhật ứng dụng. Việc tiếp tục sử dụng ứng dụng sau khi có thay đổi đồng nghĩa với việc chấp nhận các điều khoản mới.";
"tos_contact_title" = "10. Thông tin liên hệ";
"tos_contact_text" = "Nếu có thắc mắc về các Điều khoản dịch vụ này, vui lòng liên hệ với chúng tôi theo địa chỉ timmy@LLM Hub.app";
