# This file is sourced by gradlew to set environment variables
# It helps Android Studio find node when not launched from terminal

# Keep an already-selected Node toolchain (CI setup-node, nvm, Volta) first.
if command -v node >/dev/null 2>&1; then
    export NODE_BINARY="$(command -v node)"
elif [ -x "/opt/homebrew/bin/node" ]; then
    export PATH="/opt/homebrew/bin:$PATH"
    export NODE_BINARY="/opt/homebrew/bin/node"
elif [ -x "/usr/local/bin/node" ]; then
    export PATH="/usr/local/bin:$PATH"
    export NODE_BINARY="/usr/local/bin/node"
elif [ -x "$HOME/.nvm/current/bin/node" ]; then
    export PATH="$HOME/.nvm/current/bin:$PATH"
    export NODE_BINARY="$HOME/.nvm/current/bin/node"
elif [ -d "$HOME/.nvm" ]; then
    # Load NVM if available
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
fi
