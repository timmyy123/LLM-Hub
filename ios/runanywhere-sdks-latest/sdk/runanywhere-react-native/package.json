{
  "name": "runanywhere-react-native-monorepo",
  "version": "0.20.9",
  "private": true,
  "description": "RunAnywhere React Native SDK - Multi-Package Monorepo",
  "workspaces": [
    "packages/*",
    "../shared/proto-ts"
  ],
  "scripts": {
    "build": "yarn build:proto && yarn workspaces foreach -At --exclude runanywhere-react-native-monorepo --exclude @runanywhere/proto-ts run build",
    "build:proto": "yarn exec tsc -p ../shared/proto-ts/tsconfig.json",
    "typecheck": "yarn typecheck:proto && yarn workspace @runanywhere/core build && yarn workspaces foreach -At --exclude runanywhere-react-native-monorepo --exclude @runanywhere/proto-ts run typecheck",
    "typecheck:proto": "yarn exec tsc -p ../shared/proto-ts/tsconfig.json --noEmit",
    "lint": "yarn workspaces foreach -A --exclude runanywhere-react-native-monorepo --exclude @runanywhere/proto-ts run lint",
    "lint:fix": "yarn workspaces foreach -A --exclude runanywhere-react-native-monorepo --exclude @runanywhere/proto-ts run lint:fix",
    "clean": "yarn workspaces foreach -A --exclude runanywhere-react-native-monorepo --exclude @runanywhere/proto-ts run clean && rm -rf ../shared/proto-ts/dist",
    "example": "yarn workspace runanywhere-example",
    "core:nitrogen": "yarn workspace @runanywhere/core nitrogen",
    "core:prepare": "yarn workspace @runanywhere/core nitrogen",
    "llamacpp:nitrogen": "yarn workspace @runanywhere/llamacpp nitrogen",
    "llamacpp:prepare": "yarn workspace @runanywhere/llamacpp nitrogen",
    "onnx:nitrogen": "yarn workspace @runanywhere/onnx nitrogen",
    "onnx:prepare": "yarn workspace @runanywhere/onnx nitrogen",
    "qhexrt:nitrogen": "yarn workspace @runanywhere/qhexrt nitrogen",
    "qhexrt:prepare": "yarn workspace @runanywhere/qhexrt nitrogen",
    "nitrogen:all": "yarn core:nitrogen && yarn llamacpp:nitrogen && yarn onnx:nitrogen && yarn qhexrt:nitrogen",
    "core:download-ios": "cd packages/core && pod install --project-directory=ios",
    "core:download-android": "cd packages/core/android && ./gradlew downloadNativeLibs",
    "llamacpp:download-ios": "cd packages/llamacpp && pod install --project-directory=ios",
    "llamacpp:download-android": "cd packages/llamacpp/android && ./gradlew downloadNativeLibs",
    "onnx:download-ios": "cd packages/onnx && pod install --project-directory=ios",
    "onnx:download-android": "cd packages/onnx/android && ./gradlew downloadNativeLibs",
    "release": "lerna publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RunanywhereAI/runanywhere-sdks.git",
    "directory": "sdk/runanywhere-react-native"
  },
  "author": "RunAnywhere AI <team@runanywhere.ai> (https://runanywhere.ai)",
  "license": "SEE LICENSE IN ../../LICENSE",
  "bugs": {
    "url": "https://github.com/RunanywhereAI/runanywhere-sdks/issues"
  },
  "homepage": "https://runanywhere.ai",
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.0",
    "@evilmartians/lefthook": "^1.13.2",
    "@types/node": "^24.10.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "commitlint": "^21.0.1",
    "del-cli": "^5.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "lerna": "^8.2.4",
    "prettier": "^3.8.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@3.6.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
