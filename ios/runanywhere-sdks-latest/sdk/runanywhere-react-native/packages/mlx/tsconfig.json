{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@runanywhere/core": ["../core/src"],
      "@runanywhere/core/*": ["../core/src/*"],
      "@runanywhere/mlx": ["./src"],
      "@runanywhere/mlx/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib"],
  "references": [
    { "path": "../core" }
  ]
}
