{
  "name": "@runanywhere/mlx",
  "version": "0.20.9",
  "description": "Apple MLX backend registration for the RunAnywhere React Native SDK",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "ios",
    "!ios/build",
    "scripts",
    "react-native.config.js",
    "LICENSE",
    "*.podspec"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "tsc -b --clean && rm -rf lib",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "prepack": "node scripts/validate-native-artifacts.js",
    "prepublishOnly": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "react-native",
    "runanywhere",
    "mlx",
    "apple",
    "metal",
    "on-device"
  ],
  "homepage": "https://runanywhere.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RunanywhereAI/runanywhere-sdks.git",
    "directory": "sdk/runanywhere-react-native/packages/mlx"
  },
  "bugs": {
    "url": "https://github.com/RunanywhereAI/runanywhere-sdks/issues"
  },
  "author": "RunAnywhere AI <team@runanywhere.ai> (https://runanywhere.ai)",
  "license": "SEE LICENSE IN LICENSE",
  "peerDependencies": {
    "@runanywhere/core": ">=0.20.9",
    "react": ">=19.0.0",
    "react-native": ">=0.83.1",
    "react-native-nitro-modules": "^0.33.9"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "react-native-nitro-modules": "^0.33.9",
    "typescript": "^5.9.3"
  }
}
