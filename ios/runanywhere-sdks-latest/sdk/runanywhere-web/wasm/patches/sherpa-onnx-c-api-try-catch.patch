diff --git a/sherpa-onnx/csrc/session.cc b/sherpa-onnx/csrc/session.cc
index 5e31165..c2c43d2 100755
--- a/sherpa-onnx/csrc/session.cc
+++ b/sherpa-onnx/csrc/session.cc
@@ -47,9 +47,25 @@ Ort::SessionOptions GetSessionOptionsImpl(
   Provider p = StringToProvider(provider_str);

   Ort::SessionOptions sess_opts;
+#ifdef __EMSCRIPTEN__
+  // RACommons patch: the Web SDK ships a WASM build without
+  // pthread / shared-memory support (so the speech artifact can be loaded
+  // without Cross-Origin Isolation). ORT's threadpool factory still calls
+  // pthread_create when `thread_pool_size > 1`, which then fails with
+  // ENOSYS / "No such file or directory" and aborts session construction.
+  // Setting both intra/inter op counts to 1 makes ORT bail out of
+  // `CreateThreadPoolHelper` at the `thread_pool_size <= 1` check (line ~123
+  // of `core/util/thread_utils.cc`) and run everything inline on the main
+  // thread without spawning workers. We deliberately avoid 0 here because
+  // that triggers `GetNumPhysicalCpuCores()` auto-detect, which may return
+  // > 1 on multi-core hosts and re-enter the pthread_create path.
+  (void)num_threads;
+  sess_opts.SetIntraOpNumThreads(1);
+  sess_opts.SetInterOpNumThreads(1);
+#else
   sess_opts.SetIntraOpNumThreads(num_threads);
-
   sess_opts.SetInterOpNumThreads(num_threads);
+#endif

   std::vector<std::string> available_providers = Ort::GetAvailableProviders();
   std::ostringstream os;
