# =============================================================================
# RunAnywhere Commons - Dependency Versions
# =============================================================================
# This file is the SINGLE SOURCE OF TRUTH for all dependency versions.
# All scripts and CMake files should read from this file via:
#   - Shell scripts: source scripts/load-versions.sh
#   - CMake: include(LoadVersions)
#
# IMPORTANT: These versions MUST match runanywhere-core/VERSIONS
# The ONNX Runtime version used here must match what's in runanywhere-swift/Binaries/
#
# Format: KEY=VALUE (no spaces around =)
# Lines starting with # are comments
# =============================================================================

# Project version (read from VERSION file, but also defined here for scripts)
PROJECT_VERSION=0.20.9

# =============================================================================
# Platform Deployment Targets
# =============================================================================
# Apple deployment floors used by SwiftPM and every packaged XCFramework.
IOS_DEPLOYMENT_TARGET=17.5
MACOS_DEPLOYMENT_TARGET=14.5

# Android minimum SDK version
ANDROID_MIN_SDK=24

# =============================================================================
# Build Tools
# =============================================================================
# Xcode version for CI/CD builds
# (2026-07-11 build-toolchain bump): 26.5 -> 26.6. GitHub's macos-26
# image and the release host both provide this exact stable build.
XCODE_VERSION=26.6
XCODE_BUILD=17F113

# Android NDK (matches what scripts/build-android.sh and Kotlin SDK expect)
# (2026-05-19 build-toolchain bump): 27.0.12077973 -> 27.3.13750724.
# 27.3.13750724 is "r27d", the CURRENT LTS designation per
# https://developer.android.com/ndk/downloads ("Latest LTS Version (r27d)").
# Note: although NDK 28.x and 29.x are published on the SDK repo channel, only
# the r27 line carries the LTS label, so we hold on the latest r27 patch.
NDK_VERSION=27.3.13750724

# Emscripten SDK (used by sdk/runanywhere-web/wasm/scripts/build.sh)
# (2026-07-10 Web release bump): 5.0.6 -> 6.0.2. Keep the setup script and
# WASM archive provenance markers sourced from this canonical pin.
EMSCRIPTEN_VERSION=6.0.2

# Node (Web SDK + React Native SDK builds)
# (2026-05-19 build-toolchain bump): 20 -> 22 (LTS).
NODE_VERSION=24

# JDK (Kotlin SDK + Android builds)
JAVA_VERSION=17

# Flutter SDK version. Single source of truth for:
#   - .github/workflows/pr-build.yml (flutter-pubget job)
#   - .github/workflows/release.yml (validate_consumer_flutter job)
#   - sdk/runanywhere-flutter/.fvm/fvm_config.json (local FVM)
# Bump here, then run setup-toolchain with platform=flutter (or sdk-only).
# (2026-07-11 stable patch bump): 3.44.0 -> 3.44.6.
FLUTTER_VERSION=3.44.6
FLUTTER_GRADLE_VERSION=9.1.0
FLUTTER_AGP_VERSION=9.0.1
FLUTTER_KOTLIN_VERSION=2.3.20
FLUTTER_ANDROID_COMPILE_SDK=36
FLUTTER_ANDROID_TARGET_SDK=36
FLUTTER_NDK_VERSION=28.2.13676358

# =============================================================================
# IDL Codegen Toolchain (single source of truth)
# =============================================================================
# Cross-language wire-compatibility depends on every generator emitting
# identical bytes from identical .proto files. These pins are consumed by:
#   - scripts/setup/setup-toolchain.sh    (installs the pinned versions)
#   - idl/codegen/generate_*.sh     (verifies the pinned versions at runtime)
#   - gradle/libs.versions.toml     (Wire runtime, mirrored by hand)
#   - .syncpackrc.json              (ts-proto if added to centralized npm pins)
#
# When bumping any of these, update ALL mirrors in the same commit and
# regenerate IDL bindings (idl/codegen/generate_all.sh) so idl-drift-check
# stays green.
# (2026-05-19 idl-codegen bump): 1.181.1 -> 2.11.8 (latest).
# Major bump: ts-proto 2.x switched to ES modules + dropped the `protobufjs`
# polyfill default. Generated TS still parses under tsc 5.9 strict.
TS_PROTO_VERSION=2.11.8
# WIRE_VERSION held within 5.x — 6.x reshuffles the Kotlin proto runtime
# package. Mirrored by hand in gradle/libs.versions.toml (already set to
# 5.5.1 there; this VERSIONS entry is the SoT mirror for setup-toolchain).
WIRE_VERSION=5.5.1
# SWIFT_PROTOBUF_VERSION stays at 1.38.0 (already latest stable as of
# 2026-05-19; release tag matches v1.38.0 on apple/swift-protobuf).
SWIFT_PROTOBUF_VERSION=1.38.0
# Python descriptor parsing used by the convenience generators. Keep within
# protobuf 6.x to match current CI installs while avoiding surprise 7.x drift.
PYTHON_PROTOBUF_VERSION=6.33
# (2026-05-19 idl-codegen bump): 22.0.0 -> 25.0.0 (latest stable on
# pub.dev). protoc_plugin 25.x emits Dart bindings that require the
# `protobuf` 6.x runtime — pubspec.yaml is bumped in lockstep. Requires
# Dart 3.0+ at codegen time (Flutter 3.44 bundles Dart 3.10).
PROTOC_GEN_DART_VERSION=25.0.0
# (2026-07-05 idl-codegen bump): 34 -> 35 (matches libprotobuf
# C++ pin 35.1 used by sdk/runanywhere-commons/src/generated/proto/*.pb.cc).
# The C++ generator emits exact runtime patch guards, so keep this in lockstep
# with PROTOBUF_VERSION below and regenerate IDL bindings when it changes.
PROTOC_VERSION_MAJOR=35

# CMake version installed in CI. Toolchain present on the build host.
# (2026-05-19 build-toolchain bump): 3.27 -> 4.3.2 (latest stable per cmake.org).
# This is the version present on the build host; MIN_CMAKE_VERSION (below) is
# the floor that each CMakeLists.txt advertises.
CMAKE_VERSION=4.3.2

# Minimum CMake version advertised by every `cmake_minimum_required()` in this
# repo. Must be >= 3.24 because cmake/FetchONNXRuntime.cmake uses the
# DOWNLOAD_EXTRACT_TIMESTAMP keyword which was added in CMake 3.24. Bumping
# this drops support for older CMake hosts; CI/devs need this version+.
# NOTE: `cmake_minimum_required(VERSION ...)` must be the first command and
# cannot be parameterised by a CMake variable — keep the literal value in
# each CMakeLists.txt in sync with this when bumping.
# Bumped from 3.24 to 3.30; reverted to 3.24 because some CI Docker
# base images still ship cmake 3.27 and the bump caused configure failures.
MIN_CMAKE_VERSION=3.24

# =============================================================================
# ONNX Runtime
# =============================================================================
# iOS version MUST match:
#   1. What sherpa-onnx was built against
#   2. What's in runanywhere-swift/Binaries/onnxruntime.xcframework
# sherpa-onnx 1.13.x requires ONNX Runtime 1.24.x. The iOS pod-archive lags
# upstream by one patch — 1.24.4 was not published as of 2026-05-19, so iOS is
# pinned to 1.24.3 (ABI-compatible with sherpa 1.13.2 across 1.24.x patches).
ONNX_VERSION_IOS=1.24.3

# Android ONNX Runtime ships inside the pinned Sherpa-ONNX Android archive.
# The archive's ELF version definition is VERS_1.24.3; keep this source/header
# commit and the runtime declaration aligned with that inspected binary.
ONNX_VERSION_ANDROID=1.24.3
ONNX_COMMIT_ANDROID=3a728b75062256951b6e19ce718907cf1a1d4cf0

# macOS version (can use latest)
# ORT v1.24+ ships per-arch tarballs only (no more osx-universal2). The
# FetchONNXRuntime.cmake macOS branch now selects osx-arm64 vs osx-x86_64
# based on CMAKE_HOST_SYSTEM_PROCESSOR.
ONNX_VERSION_MACOS=1.24.4

# Linux version (can use latest)
ONNX_VERSION_LINUX=1.24.4

# Windows version (can use latest)
ONNX_VERSION_WINDOWS=1.24.4

# Web/WASM version. This is intentionally independent from the native platform
# pins above: Sherpa-ONNX v1.13.4's upstream WASM bundle is matched to ORT
# v1.27.1, while the shipped iOS/Android binaries remain on their validated
# platform-specific versions.
ONNX_VERSION_WEB=1.27.1
ONNX_COMMIT_WEB=df2ba1cf8108aa63627cf4cdf8f807880b938616

# =============================================================================
# Sherpa-ONNX (via runanywhere-core)
# =============================================================================
# iOS version. Consume the upstream release archive directly so every native
# platform compiles against the same current C API instead of retaining an old
# integration solely because a mirrored binary lagged behind upstream.
SHERPA_ONNX_VERSION_IOS=1.13.2
SHERPA_ONNX_IOS_SHA256=2886a04df4f8d5066c6c8b6e712278d65d7b60fc9e45990223df50262861d38b

# Android version (v1.12.20+ has 16KB alignment for Play Store)
# The downloader invalidates its cache whenever the repository, version,
# source/header commit, runtime commit, patch hash, or archive digest changes.
SHERPA_ONNX_VERSION_ANDROID=1.13.2
# Android prebuilt source repo. This personal-repository release is retained
# temporarily because its Whisper greedy decoder populates per-token
# ys_log_probs for hybrid-router confidence. The downloader verifies the exact
# inspected archive; these pins do not constitute build provenance or an
# upstream attestation.
SHERPA_ONNX_REPO_ANDROID=Siddhesh2377/sherpa-onnx-rac
SHERPA_ONNX_COMMIT_ANDROID=707ffc40b0fd59c04f50998e72989dd816b1dd37
SHERPA_ONNX_ANDROID_SHA256=6ce931ffb49605cf1448e5fa98f9804fb7fdc5bb72efded3048a84080eea477b
# The fork commit is one behavior-only patch over this signed upstream commit.
# The SHA-256 is for the exact three-file git diff, not the release archive.
SHERPA_ONNX_UPSTREAM_COMMIT_ANDROID=13d0ae6c539d2809d32f5eaa3ef1db0c459d0b24
SHERPA_ONNX_PATCH_SHA256_ANDROID=f71a4ee115b72871c2ef821b7bf1eaed9eeddd2d9c9d59ee002b8fca507dbb35
# Public C/C++ headers are unchanged by the patch; fetch them from the signed
# upstream source commit instead of the fork's mutable release tag.
SHERPA_ONNX_HEADER_REPO_ANDROID=k2-fsa/sherpa-onnx
SHERPA_ONNX_HEADER_COMMIT_ANDROID=13d0ae6c539d2809d32f5eaa3ef1db0c459d0b24

# macOS version
SHERPA_ONNX_VERSION_MACOS=1.13.2
SHERPA_ONNX_COMMIT_MACOS=13d0ae6c539d2809d32f5eaa3ef1db0c459d0b24

# Linux version
SHERPA_ONNX_VERSION_LINUX=1.13.2

# Windows version
SHERPA_ONNX_VERSION_WINDOWS=1.13.2

# Web/WASM matched set with ONNX_VERSION_WEB. Do not reuse Android/iOS
# prebuilts for this target; the Web vendor scripts validate provenance.
SHERPA_ONNX_VERSION_WEB=1.13.4
SHERPA_ONNX_COMMIT_WEB=142807252687d81b40d6315f23470a1512a00de3

# =============================================================================
# llama.cpp (LLM inference)
# =============================================================================
# Upstream release pin selected for the 2026-07-10 Web release cut. b9959
# includes the ARMv7 table-lookup fallback required by Android builds.
LLAMACPP_VERSION=b9959

# =============================================================================
# nlohmann/json
# =============================================================================
NLOHMANN_JSON_VERSION=3.12.0

# =============================================================================
# USearch (vector search engine used by the RAG pipeline)
# =============================================================================
USEARCH_VERSION=v2.25.2

# =============================================================================
# cpp-httplib (header-only HTTP server — RAC_BUILD_SERVER only)
# =============================================================================
CPPHTTPLIB_VERSION=v0.45.0

# =============================================================================
# zlib (bundled for Android/Emscripten where the platform SDK lacks it)
# =============================================================================
ZLIB_VERSION=v1.3.2

# =============================================================================
# bzip2 (bundled for Android/Emscripten — sourceware tarball, NOT a `v` prefix)
# =============================================================================
BZIP2_VERSION=1.0.8

# =============================================================================
# Protobuf (libprotobuf runtime + matching libprotobuf-lite/abseil)
# =============================================================================
# Must match what the checked-in generated headers under
# sdk/runanywhere-commons/src/generated/proto/ were emitted by (Protobuf C++
# 7.35.1 → upstream tag v35.1). Bumping requires regenerating those headers.
PROTOBUF_VERSION=35.1

# Protobuf 35.1 is built and distributed by the supported Homebrew toolchain
# against this Abseil release. Pre-fetch the exact same source for the private
# static protobuf runtime so generated-header consumers and packaged symbols
# share one Abseil inline namespace without linking host dylibs.
ABSEIL_VERSION=20260107.1

# =============================================================================
# GoogleTest (test framework for commons + RAG unit tests)
# =============================================================================
GOOGLETEST_VERSION=v1.17.0

# =============================================================================
# libarchive (archive extraction - ZIP, TAR.GZ, TAR.BZ2, TAR.XZ)
# =============================================================================
LIBARCHIVE_VERSION=3.8.7

# =============================================================================
# RAC Commons Version (for remote builds/CI)
# =============================================================================
RAC_COMMONS_VERSION=0.1.1
