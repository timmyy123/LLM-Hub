<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for localhost (native SD backend server) and block it everywhere else.
         NOTE: No <domain-config> blocks here — their presence causes Android's RootTrustManager
         to reject the 2-arg checkServerTrusted used by Ktor CIO (WhisperKit internal), breaking
         all HTTPS connections from WhisperKit. Cleartext is only reachable via localhost anyway. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
